{
  "name": "Workflow 3 - Rappels RDV",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 6
            }
          ]
        }
      },
      "id": "cron-6h",
      "name": "Cron toutes les 6h",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  a.id,\n  a.title,\n  a.starts_at,\n  a.ends_at,\n  a.location,\n  a.reminder_sent_j2,\n  p.email as client_email,\n  p.full_name as client_name,\n  av.full_name as avocat_name\nFROM appointments a\nJOIN profiles p ON p.id = a.client_id\nJOIN avocats av ON av.id = a.avocat_id\nWHERE \n  a.status = 'scheduled'\n  AND a.starts_at > NOW()\n  AND a.starts_at <= NOW() + INTERVAL '2 days'\n  AND a.starts_at >= NOW() + INTERVAL '1.5 days'\n  AND a.reminder_sent_j2 = false\nORDER BY a.starts_at ASC;"
      },
      "id": "query-rdv-j2",
      "name": "Query RDV J-2 (email)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [450, 200],
      "credentials": {
        "postgres": {
          "id": "supabase-db",
          "name": "Supabase Postgres"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  a.id,\n  a.title,\n  a.starts_at,\n  a.ends_at,\n  a.location,\n  a.reminder_sent_j1,\n  p.phone as client_phone,\n  p.full_name as client_name,\n  av.full_name as avocat_name\nFROM appointments a\nJOIN profiles p ON p.id = a.client_id\nJOIN avocats av ON av.id = a.avocat_id\nWHERE \n  a.status = 'scheduled'\n  AND a.starts_at > NOW()\n  AND a.starts_at <= NOW() + INTERVAL '1 day'\n  AND a.starts_at >= NOW() + INTERVAL '20 hours'\n  AND a.reminder_sent_j1 = false\n  AND p.phone IS NOT NULL\nORDER BY a.starts_at ASC;"
      },
      "id": "query-rdv-j1",
      "name": "Query RDV J-1 (SMS)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [450, 400],
      "credentials": {
        "postgres": {
          "id": "supabase-db",
          "name": "Supabase Postgres"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ $json.id }}",
              "operation": "isNotEmpty"
            }
          ]
        }
      },
      "id": "check-j2-results",
      "name": "RDV J-2 trouvés?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [650, 200]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ $json.id }}",
              "operation": "isNotEmpty"
            }
          ]
        }
      },
      "id": "check-j1-results",
      "name": "RDV J-1 trouvés?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [650, 400]
    },
    {
      "parameters": {
        "fromEmail": "rdv@maison-alderic.be",
        "toEmail": "={{ $json.client_email }}",
        "subject": "Rappel : votre rendez-vous dans 2 jours",
        "emailFormat": "html",
        "text": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <style>\n    body { font-family: Inter, sans-serif; color: #1A1A1A; background: #F8F7F4; }\n    .container { max-width: 600px; margin: 40px auto; background: #FFFFFF; padding: 40px; border-radius: 4px; }\n    h1 { font-family: Fraunces, serif; font-size: 24px; font-weight: 500; color: #1A1A1A; margin: 0 0 24px 0; }\n    .detail { margin: 12px 0; color: #5C5A55; }\n    .label { font-weight: 500; color: #1A1A1A; }\n    .footer { margin-top: 40px; padding-top: 24px; border-top: 1px solid #E5E2DB; color: #8B887F; font-size: 14px; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Rappel de rendez-vous</h1>\n    <p>Bonjour {{ $json.client_name }},</p>\n    <p>Nous vous rappelons que vous avez un rendez-vous dans <strong>2 jours</strong> :</p>\n    \n    <div style=\"background: #F2F0EB; padding: 20px; border-radius: 4px; margin: 24px 0;\">\n      <div class=\"detail\"><span class=\"label\">Sujet :</span> {{ $json.title }}</div>\n      <div class=\"detail\"><span class=\"label\">Date :</span> {{ $fromDateTime($json.starts_at).toFormat('EEEE d MMMM yyyy', { locale: 'fr' }) }}</div>\n      <div class=\"detail\"><span class=\"label\">Heure :</span> {{ $fromDateTime($json.starts_at).toFormat('HH:mm') }} - {{ $fromDateTime($json.ends_at).toFormat('HH:mm') }}</div>\n      <div class=\"detail\"><span class=\"label\">Avec :</span> {{ $json.avocat_name }}</div>\n      <div class=\"detail\"><span class=\"label\">Lieu :</span> {{ $json.location }}</div>\n    </div>\n    \n    <p>Si vous avez besoin d'annuler ou de reporter ce rendez-vous, merci de nous contacter au plus vite au +32 2 555 01 23.</p>\n    \n    <div class=\"footer\">\n      <strong>Maison Aldéric & Associés</strong><br>\n      Avenue Louise 480, 1050 Bruxelles<br>\n      <a href=\"mailto:rdv@maison-alderic.be\" style=\"color: #7A1F2B;\">rdv@maison-alderic.be</a>\n    </div>\n  </div>\n</body>\n</html>"
      },
      "id": "send-email-j2",
      "name": "Envoyer email J-2",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [850, 150],
      "credentials": {
        "smtp": {
          "id": "resend-smtp",
          "name": "Resend SMTP"
        }
      }
    },
    {
      "parameters": {
        "fromPhoneNumber": "={{ $vars.TWILIO_PHONE }}",
        "toPhoneNumber": "={{ $json.client_phone }}",
        "message": "Maison Aldéric & Associés — Rappel : RDV demain {{ $fromDateTime($json.starts_at).toFormat('HH:mm') }} avec {{ $json.avocat_name }}. Lieu : {{ $json.location }}. Pour annuler : +32 2 555 01 23"
      },
      "id": "send-sms-j1",
      "name": "Envoyer SMS J-1 (Twilio)",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [850, 350],
      "credentials": {
        "twilioApi": {
          "id": "twilio",
          "name": "Twilio"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE appointments\nSET reminder_sent_j2 = true,\n    updated_at = NOW()\nWHERE id = '{{ $json.id }}'::uuid\nRETURNING id;"
      },
