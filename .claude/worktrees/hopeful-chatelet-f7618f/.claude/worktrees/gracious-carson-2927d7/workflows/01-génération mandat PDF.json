        "html": "=<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n</head>\n<body style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 0; background-color: #f4f4f4;\">\n  <div style=\"background-color: #ffffff; padding: 40px 30px; border-radius: 8px; margin: 20px;\">\n    <!-- Header -->\n    <div style=\"text-align: center; border-bottom: 2px solid #8B7355; padding-bottom: 20px; margin-bottom: 30px;\">\n      <h1 style=\"color: #8B7355; margin: 0; font-size: 24px; letter-spacing: 1px;\">MAISON ALDÉRIC</h1>\n      <p style=\"color: #666; margin: 5px 0; font-size: 12px;\">Cabinet d'Avocats — Bruxelles</p>\n    </div>\n\n    <!-- Titre -->\n    <h2 style=\"color: #1a1a1a; font-size: 20px; margin-bottom: 20px;\">Nouveau mandat signé</h2>\n\n    <!-- Infos mandat -->\n    <div style=\"background-color: #f9f7f4; padding: 20px; border-radius: 6px; margin-bottom: 25px;\">\n      <table style=\"width: 100%; border-collapse: collapse;\">\n        <tr>\n          <td style=\"padding: 8px 0; color: #666; font-size: 14px;\"><strong>Client :</strong></td>\n          <td style=\"padding: 8px 0; color: #1a1a1a; font-size: 14px;\">{{ $json.body.client_nom }}</td>\n        </tr>\n        <tr>\n          <td style=\"padding: 8px 0; color: #666; font-size: 14px;\"><strong>Avocat :</strong></td>\n          <td style=\"padding: 8px 0; color: #1a1a1a; font-size: 14px;\">Maître {{ $json.body.avocat_nom }}</td>\n        </tr>\n        <tr>\n          <td style=\"padding: 8px 0; color: #666; font-size: 14px;\"><strong>Type de dossier :</strong></td>\n          <td style=\"padding: 8px 0; color: #1a1a1a; font-size: 14px;\">{{ $json.body.type_dossier }}</td>\n        </tr>\n        <tr>\n          <td style=\"padding: 8px 0; color: #666; font-size: 14px;\"><strong>Honoraires estimés :</strong></td>\n          <td style=\"padding: 8px 0; color: #1a1a1a; font-size: 14px;\">{{ $json.body.honoraires_estimes }} {{ $json.body.devise }}</td>\n        </tr>\n        <tr>\n          <td style=\"padding: 8px 0; color: #666; font-size: 14px;\"><strong>Numéro :</strong></td>\n          <td style=\"padding: 8px 0; color: #1a1a1a; font-size: 14px;\">{{ $json.numero_mandat }}</td>\n        </tr>\n      </table>\n    </div>\n\n    <!-- Description -->\n    <div style=\"margin-bottom: 25px;\">\n      <p style=\"color: #666; font-size: 14px; line-height: 1.6; margin: 0;\">\n        <strong>Description :</strong><br>\n        {{ $json.body.description }}\n      </p>\n    </div>\n\n    <!-- Note PDF -->\n    <div style=\"background-color: #e8f5e9; padding: 15px; border-radius: 6px; margin-bottom: 25px;\">\n      <p style=\"color: #2e7d32; font-size: 13px; margin: 0;\">\n        ✓ Le mandat PDF a été généré et est disponible dans votre portail client.\n      </p>\n    </div>\n\n    <!-- CTA -->\n    <div style=\"text-align: center; margin: 30px 0;\">\n      <a href=\"https://portail.maisonalderic.be/dossiers/{{ $json.body.dossier_id }}\" \n         style=\"display: inline-block; background-color: #8B7355; color: #ffffff; padding: 12px 30px; text-decoration: none; border-radius: 4px; font-size: 14px;\">\n        Accéder au portail\n      </a>\n    </div>\n\n    <!-- Footer -->\n    <div style=\"border-top: 1px solid #e0e0e0; padding-top: 20px; margin-top: 30px; text-align: center;\">\n      <p style=\"color: #999; font-size: 11px; margin: 5px 0;\">\n        Ce message a été généré automatiquement<br>\n        Maison Aldéric — Avenue Louise 250, 1050 Bruxelles<br>\n        <a href=\"mailto:contact@maisonalderic.be\" style=\"color: #8B7355; text-decoration: none;\">contact@maisonalderic.be</a>\n      </p>\n    </div>\n  </div>\n</body>\n</html>",
        "options": {
          "appendAttribution": false
        }
